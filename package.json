{
  "name": "tachu",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": ["packages/*"],
    "catalog": {
      "@anthropic-ai/sdk": "^0.90.0",
      "@modelcontextprotocol/sdk": "^1.29.0",
      "@mozilla/readability": "^0.6.0",
      "@opentelemetry/api": "^1.9.1",
      "@opentelemetry/core": "^2.7.0",
      "@opentelemetry/exporter-metrics-otlp-http": "^0.215.0",
      "@opentelemetry/resources": "^2.7.0",
      "@opentelemetry/sdk-metrics": "^2.7.0",
      "@opentelemetry/sdk-trace-base": "^2.7.0",
      "@opentelemetry/sdk-trace-node": "^2.7.0",
      "@qdrant/js-client-rest": "^1.17.0",
      "@types/bun": "^1.3.12",
      "@types/turndown": "^5.0.6",
      "bun-types": "1.3.12",
      "citty": "^0.2.2",
      "cli-highlight": "2.1.11",
      "gray-matter": "^4.0.3",
      "linkedom": "^0.18.12",
      "mammoth": "^1.12.0",
      "marked": "14.1.4",
      "marked-terminal": "7.3.0",
      "openai": "^6.34.0",
      "pdf-parse": "^2.4.5",
      "playwright-core": "^1.59.1",
      "playwright-extra": "^4.3.6",
      "puppeteer-extra-plugin-stealth": "^2.11.2",
      "tiktoken": "^1.0.22",
      "turndown": "^7.2.4",
      "turndown-plugin-gfm": "^1.0.2",
      "typescript": "^6.0.3"
    }
  },
  "overrides": {
    "cli-highlight": {
      "chalk": "4.1.2"
    },
    "marked-terminal": {
      "chalk": "5.6.2"
    }
  },
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "test:integration": "bun test __tests__/integration",
    "bench": "bun run --filter '@tachu/core' bench",
    "typecheck": "bun run --filter '*' typecheck",
    "clean": "bun run --filter '*' clean",
    "dev:server": "bun run --filter '@tachu/web-fetch-server' dev",
    "dev:server:install-browser": "bun run --filter '@tachu/web-fetch-server' install:browser",
    "docker:server": "docker compose -f packages/web-fetch-server/docker-compose.yml up --build",
    "release": "bash scripts/publish.sh",
    "release:dry": "bash scripts/publish.sh --dry-run",
    "release:beta": "bash scripts/publish.sh --tag=beta",
    "release:latest": "bash scripts/publish.sh --tag=latest"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "bun-types": "catalog:",
    "typescript": "catalog:"
  }
}
