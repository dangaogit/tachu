{
  "name": "@tachu/cli",
  "version": "1.0.0-alpha.1",
  "description": "Tachu CLI (alpha) — tachu init/run/chat commands with streaming renderer, interactive session persistence, descriptor scanning and config loader. Reference implementation of @tachu/core.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "tachu": "./bin/tachu.mjs"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "README_ZH.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "tachu",
    "cli",
    "agent",
    "llm",
    "chat",
    "repl",
    "bun",
    "typescript"
  ],
  "author": "Tachu Contributors",
  "license": "Apache-2.0",
  "homepage": "https://github.com/dangaogit/tachu#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dangaogit/tachu.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/dangaogit/tachu/issues"
  },
  "engines": {
    "bun": ">=1.3.12"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@tachu/core": "workspace:*",
    "@tachu/extensions": "workspace:*",
    "citty": "catalog:",
    "cli-highlight": "catalog:",
    "gray-matter": "catalog:",
    "ink": "5.2.0",
    "ink-spinner": "5.0.0",
    "ink-text-input": "^6.0.0",
    "marked": "catalog:",
    "marked-terminal": "catalog:",
    "react": "18.3.1"
  },
  "scripts": {
    "build": "bun run clean && bunx tsc -p tsconfig.build.json && bun ../../scripts/copy-md-assets.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "bun test",
    "test:coverage": "bun test --coverage"
  },
  "devDependencies": {
    "@types/react": "18.3.12"
  }
}
