{
  "name": "@tachu/extensions",
  "version": "1.0.0-alpha.2",
  "description": "Tachu extensions (alpha) — OpenAI/Anthropic/Mock providers, 7 built-in tools, execution backends, MCP adapters (stdio+SSE), vector stores (local/Qdrant), observability emitters, input transformers and common rules.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "README_ZH.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "keywords": [
    "tachu",
    "agent",
    "llm",
    "openai",
    "anthropic",
    "mcp",
    "qdrant",
    "opentelemetry",
    "vector-store",
    "provider",
    "tools",
    "bun",
    "typescript"
  ],
  "author": "Tachu Contributors",
  "license": "Apache-2.0",
  "homepage": "https://github.com/dangaogit/tachu#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dangaogit/tachu.git",
    "directory": "packages/extensions"
  },
  "bugs": {
    "url": "https://github.com/dangaogit/tachu/issues"
  },
  "engines": {
    "bun": ">=1.3.12"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "catalog:",
    "@modelcontextprotocol/sdk": "catalog:",
    "@opentelemetry/api": "catalog:",
    "@opentelemetry/sdk-trace-base": "catalog:",
    "@opentelemetry/sdk-trace-node": "catalog:",
    "@qdrant/js-client-rest": "catalog:",
    "@tachu/core": "workspace:*",
    "mammoth": "catalog:",
    "openai": "catalog:",
    "pdf-parse": "catalog:"
  },
  "scripts": {
    "build": "bun run clean && bunx tsc -p tsconfig.build.json && bun ../../scripts/copy-md-assets.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "bun test",
    "test:coverage": "bun test --coverage"
  }
}
