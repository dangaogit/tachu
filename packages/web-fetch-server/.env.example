# =============================================================================
# @tachu/web-fetch-server — 环境变量示例
# 复制为 .env 后按需填写。生产环境务必设置强随机 WEB_FETCH_TOKEN（绑定非 127.0.0.1 时必填）。
# =============================================================================

# --- 2.1 服务基础 ---
# 监听地址；未设置 WEB_FETCH_TOKEN 时若 host 非 127.0.0.1 将启动失败
WEB_FETCH_HOST=
# 监听端口（默认 8787）
WEB_FETCH_PORT=
# Bearer 鉴权；空 = 未启用鉴权且仅允许绑定 127.0.0.1
WEB_FETCH_TOKEN=replace-me-in-prod
# development | production
NODE_ENV=

# --- 2.2 超时与限制 ---
WEB_FETCH_REQUEST_TIMEOUT_MS=
WEB_FETCH_DEFAULT_WAIT_TIMEOUT_MS=
WEB_FETCH_MAX_BODY_BYTES=
WEB_FETCH_MAX_REQUEST_BYTES=
WEB_FETCH_DEFAULT_MAX_BODY_CHARS=

# --- 2.3 并发与限流 ---
WEB_FETCH_MAX_CONCURRENCY=
WEB_FETCH_ACQUIRE_TIMEOUT_MS=
WEB_FETCH_RATE_LIMIT_RPM=
WEB_FETCH_RATE_LIMIT_BURST=

# --- 2.4 浏览器池 ---
WEB_FETCH_BROWSER_ENABLED=
WEB_FETCH_BROWSER_IDLE_MS=
WEB_FETCH_BROWSER_RECYCLE_AFTER=
WEB_FETCH_BROWSER_RECYCLE_INTERVAL_MS=
WEB_FETCH_STEALTH=
# 覆盖 Chromium 可执行文件路径（Docker 内常设为 /usr/bin/chromium）
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=
# 逗号分隔的 UA 池；空则使用内置列表
WEB_FETCH_UA_POOL=

# --- 2.5 安全 ---
# 逗号分隔域名白名单；空则仅 SSRF 黑名单防御
WEB_FETCH_ALLOWED_DOMAINS=
# 逗号分隔域名黑名单
WEB_FETCH_BLOCKED_DOMAINS=
# 是否放行 loopback（仅集成测试；生产须 false）
WEB_FETCH_ALLOW_LOOPBACK=

# --- 2.6 缓存（可选）---
WEB_FETCH_CACHE_TTL_MS=
WEB_FETCH_CACHE_DIR=
WEB_FETCH_CACHE_MAX_ENTRIES=
WEB_FETCH_CACHE_MAX_SIZE_MB=

# --- 2.7 可观测性（WEB_FETCH_*，与 loadConfig 一致）---
WEB_FETCH_LOG_LEVEL=
WEB_FETCH_LOG_FORMAT=
# Trace / 部分管线使用的 OTLP 端点；空则禁用对应导出路径
WEB_FETCH_OTLP_ENDPOINT=
# OTLP headers，格式 k1=v1,k2=v2
WEB_FETCH_OTLP_HEADERS=
WEB_FETCH_SERVICE_NAME=

# --- OpenTelemetry 标准环境变量（指标导出等，见 observability/metrics）---
# OTLP HTTP 端点（例如 http://127.0.0.1:4318）；未配置则指标不对外导出
OTEL_EXPORTER_OTLP_ENDPOINT=
# OTLP headers，格式 k1=v1,k2=v2
OTEL_EXPORTER_OTLP_HEADERS=

# --- 2.8 搜索（Stage 4 占位）---
WEB_SEARCH_PROVIDER=
WEB_SEARCH_PROVIDER_API_KEY=
WEB_SEARCH_PROVIDER_ENDPOINT=
WEB_SEARCH_DEFAULT_MAX_RESULTS=

# --- Client：@tachu/extensions web-fetch / web-search 工具 ---
# Server 基址（默认 http://127.0.0.1:8787）
TACHU_WEB_FETCH_ENDPOINT=
# 与 WEB_FETCH_TOKEN 对齐的 Bearer
TACHU_WEB_FETCH_TOKEN=
# 客户端整体超时（毫秒），须 ≥ 服务端请求超时
TACHU_WEB_FETCH_DEFAULT_TIMEOUT_MS=
