{
  "name": "@tachu/web-fetch-server",
  "version": "1.0.0-alpha.1",
  "description": "Tachu Web Fetch & Search rendering server (alpha) — Bun.serve + Playwright driven remote renderer that powers @tachu/extensions' web-fetch and web-search tools. NOT published to npm; deploy via Docker or `bunx git+...`.",
  "private": true,
  "type": "module",
  "author": "Tachu Contributors",
  "license": "Apache-2.0",
  "homepage": "https://github.com/dangaogit/tachu#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dangaogit/tachu.git",
    "directory": "packages/web-fetch-server"
  },
  "bugs": {
    "url": "https://github.com/dangaogit/tachu/issues"
  },
  "engines": {
    "bun": ">=1.3.12"
  },
  "bin": {
    "tachu-web-fetch-server": "./src/bin/tachu-web-fetch-server.ts"
  },
  "dependencies": {
    "@mozilla/readability": "catalog:",
    "@opentelemetry/api": "catalog:",
    "@opentelemetry/core": "catalog:",
    "@opentelemetry/exporter-metrics-otlp-http": "catalog:",
    "@opentelemetry/resources": "catalog:",
    "@opentelemetry/sdk-metrics": "catalog:",
    "@opentelemetry/sdk-trace-base": "catalog:",
    "@opentelemetry/sdk-trace-node": "catalog:",
    "@tachu/extensions": "workspace:*",
    "linkedom": "catalog:",
    "playwright-core": "catalog:",
    "playwright-extra": "catalog:",
    "puppeteer-extra-plugin-stealth": "catalog:",
    "turndown": "catalog:",
    "turndown-plugin-gfm": "catalog:"
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/turndown": "catalog:",
    "typescript": "catalog:"
  },
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "start": "bun run src/server.ts",
    "build": "bun run clean && bunx tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "install:browser": "bunx playwright install chromium --with-deps",
    "smoke": "bash scripts/smoke.sh"
  }
}
